#. i18n: ectx: label, entry (CurrentLevel), group (Language)
#: khangman.kcfg:10
#, kde-format
msgid "Level"
msgstr "Razina"

#. i18n: ectx: label, entry (SelectedLanguage), group (Language)
#: khangman.kcfg:17
#, kde-format
msgid "The language selected by the user"
msgstr "Jezik koji je korisnik odabrao"

#. i18n: ectx: label, entry (Theme), group (Look)
#: khangman.kcfg:33
#, kde-format
msgid "Background theme name"
msgstr "Naziv pozadinske teme"

#. i18n: ectx: label, entry (OneLetter), group (General)
#: khangman.kcfg:40
#, kde-format
msgid ""
"Check this if you do not want to discover each instance of the same letter."
msgstr "Provjerite ovo ako ne želite otkriti svaki primjerak istog pisma."

#. i18n: ectx: label, entry (EnableAnimations), group (General)
#: khangman.kcfg:44
#, kde-format
msgid "Enable Animations"
msgstr "Omogući animacije"

#. i18n: ectx: label, entry (Sound), group (General)
#: khangman.kcfg:48
#, kde-format
msgid "If checked, sounds will be played for New Game and Win Game"
msgstr "Ako se označi, zvukovi će se puštati za Novu igru i Pobjedu u igri"

#. i18n: ectx: label, entry (Hint), group (General)
#: khangman.kcfg:53
#, kde-format
msgid ""
"If checked, hints will always been displayed. If this is not checked "
"(default)\n"
"            hints will be displayed only per word when the user chooses to "
"show the hint."
msgstr ""
"Ako je označeno, savjeti će se uvijek prikazivati. Ako ovo nije označeno "
"(zadano)\n"
"            Savjeti će se prikazivati samo po riječi kada korisnik odluči "
"prikazati nagovještaj."

#. i18n: ectx: label, entry (resolveTime), group (General)
#: khangman.kcfg:57
#, kde-format
msgid ""
"This setting allows you to set in seconds how much time is available for "
"resolving the word."
msgstr ""
"Ova postavka omogućuje da u sekundama odredite koliko je vremena dostupno za "
"rješavanje riječi."

#. i18n: ectx: label, entry (AccentedLetters), group (Advanced)
#: khangman.kcfg:64
#, kde-format
msgid "Type accented letters separately from normal letters"
msgstr "Tipkajte naglašena slova odvojeno od običnih slova"

#. i18n: ectx: label, entry (ProvidersUrl), group (KNewStuff)
#: khangman.kcfg:71
#, kde-format
msgid "The Providers path for KHangMan"
msgstr "Put pružatelja usluga za KHangMan"

